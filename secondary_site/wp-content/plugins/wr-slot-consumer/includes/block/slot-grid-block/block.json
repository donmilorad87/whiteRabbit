{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wr-slot-consumer/slot-grid",
	"version": "1.0.0",
	"title": "Slots Grid",
	"category": "widgets",
	"icon": "grid-view",
	"description": "Display slot games in a responsive grid with full styling controls.",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"columns": { "type": "number", "default": 3 },
		"limit": { "type": "number", "default": 12 },
		"sortBy": { "type": "string", "default": "recent" },
		"paginationMode": { "type": "string", "default": "off" },
		"loadMoreType": { "type": "string", "default": "button" },
		"linkMode": { "type": "string", "default": "page" },
		"detailPageUrl": { "type": "string", "default": "" },
		"moreInfoLabel": { "type": "string", "default": "More Info" },

		"blockBgEnabled": { "type": "boolean", "default": false },
		"blockBgColor": { "type": "string", "default": "#ffffff" },
		"blockBgCustom": { "type": "boolean", "default": false },
		"blockBgCustomValue": { "type": "string", "default": "" },
		"blockPadding": { "type": "number", "default": 0 },
		"blockBorderRadius": { "type": "number", "default": 0 },

		"showMoreInfo": { "type": "boolean", "default": true },
		"btnBgColor": { "type": "string", "default": "" },
		"btnTextColor": { "type": "string", "default": "" },
		"btnBorderRadius": { "type": "number", "default": 8 },
		"btnBorderColor": { "type": "string", "default": "" },
		"btnShadowX": { "type": "number", "default": 0 },
		"btnShadowY": { "type": "number", "default": 0 },
		"btnShadowBlur": { "type": "number", "default": 0 },
		"btnShadowSpread": { "type": "number", "default": 0 },
		"btnShadowColor": { "type": "string", "default": "" },
		"btnShadowInset": { "type": "boolean", "default": false },
		"btnCustomShadow": { "type": "boolean", "default": false },
		"btnCustomShadowValue": { "type": "string", "default": "" },
		"btnTextShadowX": { "type": "number", "default": 0 },
		"btnTextShadowY": { "type": "number", "default": 0 },
		"btnTextShadowBlur": { "type": "number", "default": 0 },
		"btnTextShadowColor": { "type": "string", "default": "" },
		"btnFontWeight": { "type": "string", "default": "600" },
		"btnHoverBgColor": { "type": "string", "default": "" },
		"btnHoverTextColor": { "type": "string", "default": "" },
		"btnHoverBorderColor": { "type": "string", "default": "" },
		"btnHoverShadow": { "type": "string", "default": "" },

		"itemHoverBgColor": { "type": "string", "default": "" },
		"itemHoverBorderColor": { "type": "string", "default": "" },
		"itemHoverShadow": { "type": "string", "default": "" },
		"itemHoverTranslateY": { "type": "number", "default": -4 },

		"itemBorderColor": { "type": "string", "default": "" },
		"itemShadowX": { "type": "number", "default": 0 },
		"itemShadowY": { "type": "number", "default": 1 },
		"itemShadowBlur": { "type": "number", "default": 3 },
		"itemShadowSpread": { "type": "number", "default": 0 },
		"itemShadowColor": { "type": "string", "default": "rgba(0,0,0,0.06)" },
		"itemShadowInset": { "type": "boolean", "default": false },
		"itemCustomShadow": { "type": "boolean", "default": false },
		"itemCustomShadowValue": { "type": "string", "default": "" },
		"itemPadding": { "type": "number", "default": 0 },
		"innerPadding": { "type": "number", "default": 20 },

		"titleFontSize": { "type": "number", "default": 16 },
		"titleColor": { "type": "string", "default": "" },
		"titleLineHeight": { "type": "number", "default": 1.35 },
		"titleFontWeight": { "type": "string", "default": "650" },
		"titleFontStyle": { "type": "string", "default": "normal" },

		"descColor": { "type": "string", "default": "" },
		"descFontSize": { "type": "number", "default": 13 },
		"descFontWeight": { "type": "string", "default": "500" },
		"descFontStyle": { "type": "string", "default": "normal" },

		"starsGap": { "type": "number", "default": 2 },
		"starsColor": { "type": "string", "default": "#f0b429" },
		"starsHalfColor": { "type": "string", "default": "#e2c773" },
		"starsInfoColor": { "type": "string", "default": "" },
		"starsInfoFontSize": { "type": "number", "default": 13 },
		"starsInfoFontWeight": { "type": "string", "default": "500" },
		"starsBorderColor": { "type": "string", "default": "" },
		"starsFontSize": { "type": "number", "default": 18 },

		"itemBgEnabled": { "type": "boolean", "default": false },
		"itemBgColor": { "type": "string", "default": "#ffffff" },
		"itemBgCustom": { "type": "boolean", "default": false },
		"itemBgCustomValue": { "type": "string", "default": "" }
	},
	"textdomain": "wr-slot-consumer",
	"editorScript": "wr-sc-slot-grid-editor",
	"editorStyle": "wr-sc-slot-grid-editor",
	"style": "wr-sc-slot-grid-style"
}
