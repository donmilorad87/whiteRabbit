#. Admin Menu
msgid "Slot Consumer"
msgstr "Слот потрошач"

#. Settings Page — Tabs
msgid "Slot Consumer Settings"
msgstr "Подешавања Слот Потрошача"

msgid "Connection"
msgstr "Повезивање"

msgid "Cache & Rate Limit"
msgstr "Кеш и ограничење брзине"

msgid "API Settings"
msgstr "API подешавања"

msgid "Cache"
msgstr "Кеш"

msgid "Cache Configuration"
msgstr "Подешавања кеша"

msgid "Rate Limit (requests/minute)"
msgstr "Ограничење брзине (захтева/минут)"

msgid "Manual Sync"
msgstr "Ручна синхронизација"

#. Connection Tab
msgid "Primary Site Connection"
msgstr "Веза са примарним сајтом"

msgid "Source Site URL"
msgstr "URL изворног сајта"

msgid "Full URL of the primary site running WR Slot Manager."
msgstr "Пуна URL адреса примарног сајта на ком ради WR Slot Manager."

msgid "API Key"
msgstr "API кључ"

msgid "Must match the API key configured on the primary site."
msgstr "Мора да одговара API кључу конфигурисаном на примарном сајту."

msgid "Save Settings"
msgstr "Сачувај подешавања"

#. Cache Tab
msgid "Cache Expiry (minutes)"
msgstr "Истек кеша (минути)"

msgid "How long slot data is cached before refreshing from the primary site."
msgstr "Колико дуго се подаци о слотовима кеширају пре освежавања са примарног сајта."

msgid "API Rate Limit (requests/minute)"
msgstr "API ограничење брзине (захтева/минут)"

msgid "Maximum webhook requests per IP address per minute."
msgstr "Максималан број webhook захтева по IP адреси у минуту."

#. Sync Tab
msgid "Fetch all slot data from the primary site and rebuild the local cache."
msgstr "Преузми све податке о слотовима са примарног сајта и поново изгради локални кеш."

msgid "Sync Data"
msgstr "Синхронизуј податке"

#. AJAX Responses
msgid "Security check failed."
msgstr "Безбедносна провера није успела."

msgid "Settings saved."
msgstr "Подешавања су сачувана."

msgid "Unauthorized."
msgstr "Неовлашћен приступ."

#. translators: %d: number of slots synced
msgid "Successfully synced %d slots."
msgstr "Успешно синхронизовано %d слотова."

msgid "Source URL and API key must be configured."
msgstr "URL извора и API кључ морају бити конфигурисани."

msgid "Primary API returned HTTP %d."
msgstr "Примарни API је вратио HTTP %d."

msgid "Invalid response from primary API."
msgstr "Неисправан одговор од примарног API-ја."

