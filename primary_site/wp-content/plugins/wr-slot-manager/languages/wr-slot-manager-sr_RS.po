#. Settings Page — Tabs
msgid "Settings"
msgstr "Подешавања"

msgid "Slot Manager Settings"
msgstr "Подешавања менаџера слотова"

msgid "Connected Sites"
msgstr "Повезани сајтови"

msgid "API Settings"
msgstr "API подешавања"

msgid "Cache Configuration"
msgstr "Подешавања кеша"

#. Settings — Connected Sites Tab
msgid "Add New Site"
msgstr "Додај нови сајт"

msgid "Site URL"
msgstr "URL сајта"

msgid "Full URL of the secondary site (include port if needed)."
msgstr "Пуна URL адреса секундарног сајта (укључите порт ако је потребно)."

msgid "Add Site"
msgstr "Додај сајт"

msgid "Registered Sites"
msgstr "Регистровани сајтови"

msgid "No connected sites yet."
msgstr "Нема повезаних сајтова."

msgid "#"
msgstr "#"

msgid "Actions"
msgstr "Акције"

msgid "Update"
msgstr "Ажурирај"

msgid "Remove"
msgstr "Уклони"

#. Settings — API Tab
msgid "API Key"
msgstr "API кључ"

msgid "Share this key with secondary sites for authentication. Keep it secure."
msgstr "Поделите овај кључ са секундарним сајтовима за аутентификацију. Чувајте га безбедно."

msgid "No API key has been generated yet."
msgstr "API кључ још увек није генерисан."

msgid "Generate API Key"
msgstr "Генериши API кључ"

msgid "Regenerate API Key"
msgstr "Поново генериши API кључ"

msgid "API Rate Limit"
msgstr "API ограничење брзине"

msgid "Requests per minute"
msgstr "Захтева у минуту"

msgid "Maximum REST API requests per IP address per minute."
msgstr "Максималан број REST API захтева по IP адреси у минуту."

#. Settings — Cache Tab
msgid "Redis Cache"
msgstr "Redis кеш"

msgid "Cache Expiry (minutes)"
msgstr "Истек кеша (минути)"

msgid "How long slot data is stored in Redis before rebuilding from the database."
msgstr "Колико дуго се подаци о слотовима чувају у Redis-у пре поновног учитавања из базе."

msgid "Save Settings"
msgstr "Сачувај подешавања"

#. AJAX Responses
msgid "Security check failed."
msgstr "Безбедносна провера није успела."

msgid "Unauthorized."
msgstr "Неовлашћен приступ."

msgid "API key generated."
msgstr "API кључ је генерисан."

msgid "Site list updated."
msgstr "Листа сајтова је ажурирана."

msgid "Settings saved."
msgstr "Подешавања су сачувана."

msgid "Failed to retrieve slots."
msgstr "Преузимање слотова није успело."

