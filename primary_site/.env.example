# ======================
# MySQL Configuration
# ======================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# ======================
# WordPress Configuration
# ======================
WORDPRESS_DB_HOST=mysql:3306
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_DB_NAME=wordpress
WORDPRESS_TABLE_PREFIX=wp_

# Site setup (used by wp core install)
WORDPRESS_URL=http://local.wiserabbit.com
WORDPRESS_TITLE=WiseRabbit
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin
WORDPRESS_ADMIN_EMAIL=admin@wiserabbit.local

# ======================
# phpMyAdmin Configuration
# ======================
PMA_HOST=mysql
PMA_ABSOLUTE_URI=http://local.wiserabbit.com/pma/

# ======================
# Plugins
# ======================
INSTALL_PLUGINS=
ACTIVATE_PLUGINS=wr-slot-manager

# ======================
# Themes
# ======================
INSTALL_THEMES=twentytwentyfive
ACTIVATE_THEMES=twentytwentyfive

# ======================
# Redis Configuration
# ======================
REDIS_PORT=6379
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_LOGLEVEL=notice

# ======================
# Environment
# ======================
# dev = info logs + no SSL verify | prod = error logs only + SSL verify
ENVIRONMENT=dev

# ======================
# Theme
# ======================
# Set to false to disable frontend theme (API/backend only)
WR_THEME_ENABLED=false
